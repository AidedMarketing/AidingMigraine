  "categories": ["health", "medical", "lifestyle"],
  "screenshots": [
    {
      "src": "./icons/screenshot-narrow.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Log migraines and see your recent patterns at a glance"
    },
    {
      "src": "./icons/screenshot-wide.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Episode history with symptoms and triggers"
    }
  ],
  "shortcuts": [
    {
      "name": "Log migraine",
      "short_name": "Log",
      "description": "Quickly log a new migraine episode",
      "url": "./?action=log",
      "icons": [
        {
          "src": "./icons/icon-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "View patterns",
      "short_name": "Patterns",
      "description": "See your migraine analytics and trends",
      "url": "./?action=analytics",
      "icons": [
        {
          "src": "./icons/icon-192x192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Care & export",
      "short_name": "Care",
